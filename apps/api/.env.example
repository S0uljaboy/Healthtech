# Database (Supabase PostgreSQL URL)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# Redis Cloud URL (Upstash or Redis Enterprise)
REDIS_HOST="your-redis-endpoint"
REDIS_PORT=6379
REDIS_PASSWORD="your-redis-password"

# Next.js Frontend URL (for CORS)
FRONTEND_URL="https://your-production-domain.com"

# API Port (Render/Railway automatically sets PORT)
PORT=3001

# Sentry DSN (Observability)
SENTRY_DSN="your-sentry-dsn-for-backend"
